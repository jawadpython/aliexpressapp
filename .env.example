# Server
PORT=3000

# Admin login (browser session cookie — no bearer token)
# Default username is "admin" if omitted
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password

# Required in production — long random string (signs the session cookie)
SESSION_SECRET=change_me_to_a_long_random_secret

# Catalog is admin-paste affiliate links only. Stored links are never sent to AliExpress APIs.

# Vercel / production: add “Redis” (Upstash) from Vercel Marketplace — these are injected automatically:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Legacy (optional): only needed if you use scripts that call aliexpress.js — not used by GET /products anymore.
# APP_KEY=
# APP_SECRET=
# ALIEXPRESS_API_MODE=sg

# Optional: comma-separated origins for CORS (default allows all in dev)
# CORS_ORIGINS=http://localhost:8080
